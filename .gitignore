.Python
env/
venv/
ENV/

# IDE & OS
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Build output (generated per CI run, not committed)
# Note: out/index.html is built fresh each time from template + data/
# out/ directory itself may exist locally but is rebuilt by tools/build_site.py
out/

# Feed data (regenerated per CI run; only the *-history.json rolling caches are persisted)
# Rationale: news.json, club.json, youtube.json, results.json are outputs of the
# feed fetchers and change frequently. They're not committed because:
# 1. They're regenerated from live feeds on every build
# 2. They're point-in-time snapshots with no history value
# 3. They would cause constant merge conflicts in CI
# 4. Size: unnecessary repository bloat
data/news.json
data/club.json
data/youtube.json
data/results.json
# ROLLING CACHES live on the dedicated `data-cache` branch (written ONLY by
# CI — see build.yml). They are ignored on main so the maintainer's pushes
# can never conflict with the hourly cache bot-commits (session 13 fix).
# Local copies stay in data/ for local builds/QA; the CI copies on
# data-cache are canonical. NEVER delete the data-cache branch.
data/results-history.json
data/news-history.json
data/fixtures-audit.json
# NOTE: data/fixtures-overrides.json IS committed on main (maintainer-curated
# fixture corrections — hand-edited, must persist).
# data/fixtures-official-reference.json is LOCAL-ONLY (QA reference capture).
data/fixtures-official-reference.json

# Temporary & local
*.tmp
*.bak
.env
.env.local
secrets/
*.log

# Project working notes — local-only

CLAUDE.md
DECISIONS.md
ROADMAP.md

# Superseded design-history files — kept locally,
# deliberately not in the repo.
prototypes/
tools/build_variants.py
tools/build_internal_pages.py

# wrangler local state (created by deploys)
.wrangler/
